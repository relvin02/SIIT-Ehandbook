{
  "expo": {
    "name": "SIIT eHandbook",
    "slug": "siit-ehandbook",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/siitappicon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B5E20"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to access your location"
        }
      ]
    ],
    "ios": {
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to track your position for the institution.",
        "NSLocationAlwaysUsageDescription": "This app needs access to your location to track your position for the institution.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to your location to track your position for the institution."
      }
    },
    "android": {
      "package": "com.siit.ehandbook",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/siitappicon.png",
        "backgroundColor": "#1B5E20"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyA-TJgnLm_xs32_Jst5ZNanqBXIC5ha2Tw"
        }
      }
    },
    "web": {
      "favicon": "./assets/siitappicon.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "4166f18e-2704-4acf-8485-7a67efc263ea"
      }
    }
  }
}
